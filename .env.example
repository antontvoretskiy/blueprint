# Copy this file to .env.local for local development.
# These defaults are intentionally namespaced and avoid common local ports.

COMPOSE_PROJECT_NAME=blueprint-dev
BLUEPRINT_BIND_HOST=127.0.0.1

BLUEPRINT_APP_PORT=3231
BLUEPRINT_API_PORT=8231
BLUEPRINT_POSTGRES_PORT=55461
BLUEPRINT_REDIS_PORT=6406
BLUEPRINT_MAILPIT_WEB_PORT=8046
BLUEPRINT_MAILPIT_SMTP_PORT=1046

POSTGRES_DB=blueprint
POSTGRES_USER=blueprint
POSTGRES_PASSWORD=blueprint_dev_password

DATABASE_URL=postgresql://blueprint:blueprint_dev_password@postgres:5432/blueprint
REDIS_URL=redis://redis:6379/0
SMTP_HOST=mailpit
SMTP_PORT=1025
